pipeline {
    environment {
        PROJECT = credentials('project_id')
        REPO_PATH = credentials('repo_path')
        APP_NAME = 'binarycalculatorwebapp'
        IMAGE_TAG = "${REPO_PATH}/${APP_NAME}"
        CLUSTER = 'sofe3980u'
        CLUSTER_ZONE = 'us-central1-a'
    }

    agent {
        kubernetes {
            label 'sample-app'
            yaml """
apiVersion: v1
kind: Pod
metadata:
  labels:
    component: ci
spec:
  containers:
  - name: gcloud
    image: google/cloud-sdk:latest
    command:
    - cat
    tty: true
"""
        }
    }

    tools {
        maven 'maven'
    }

    stages {
        stage('test') {
            steps {
                sh 'mvn clean test -f ./BinaryCalculatorWebapp/pom.xml'
            }
        }

        stage('build') {
            steps {
                sh 'mvn clean package -DskipTests -f ./BinaryCalculatorWebapp/pom.xml'
            }
        }

        stage('containerize') {
            steps {
                container('gcloud') {
                    dir('BinaryCalculatorWebapp') {
                        sh '''
                            gcloud config set project "$PROJECT"
                            gcloud auth list
                            gcloud builds submit \
                              --tag "$IMAGE_TAG" \
                              --service-account="projects/$PROJECT/serviceAccounts/jenkins-sa@$PROJECT.iam.gserviceaccount.com" \
                              --gcs-log-dir="gs://$PROJECT-cloudbuild-logs" \
                              --suppress-logs
                        '''
                    }
                }
            }
        }

        stage('deployment') {
            steps {
                container('gcloud') {
                    dir('BinaryCalculatorWebapp') {
                        sh '''
                            gcloud config set project "$PROJECT"
                            gcloud auth list
                            gcloud container clusters get-credentials "$CLUSTER" --zone "$CLUSTER_ZONE" --project "$PROJECT"
                            kubectl delete deployment binarycalculator-deployment --ignore-not-found=true
                            kubectl create deployment binarycalculator-deployment --image="$IMAGE_TAG" --port=8080
                        '''
                    }
                }
            }
        }

        stage('service') {
            steps {
                container('gcloud') {
                    dir('BinaryCalculatorWebapp') {
                        sh '''
                            gcloud config set project "$PROJECT"
                            gcloud auth list
                            gcloud container clusters get-credentials "$CLUSTER" --zone "$CLUSTER_ZONE" --project "$PROJECT"
                            kubectl delete service binarycalculator-service --ignore-not-found=true
                            kubectl expose deployment binarycalculator-deployment --type=LoadBalancer --name=binarycalculator-service --port=8080 --target-port=8080
                            sleep 20
                            kubectl get service binarycalculator-service -o wide
                        '''
                    }
                }
            }
        }
    }
}
